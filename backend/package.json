    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.20.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
